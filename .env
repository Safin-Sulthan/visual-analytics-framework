# MongoDB — uses Docker service name "mongo" defined in docker-compose.yml
MONGODB_URI=mongodb://mongo:27017/visual-analytics

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Redis — uses Docker service name "redis" defined in docker-compose.yml
REDIS_URL=redis://redis:6379

# AI Engine — uses Docker service name "ai-engine" defined in docker-compose.yml
AI_ENGINE_URL=http://ai-engine:8000

# Frontend API URL (browser-facing, uses host port)
REACT_APP_API_URL=http://localhost:5000/api

# Ports
PORT=5000
AI_ENGINE_PORT=8000

# Environment
NODE_ENV=production

# Worker concurrency
WORKER_CONCURRENCY=2
